# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app_db

# =============================================================================
# Keycloak DB (second database on the same postgres instance)
# =============================================================================
KEYCLOAK_DB=keycloak_db
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=changeme

# =============================================================================
# Keycloak Admin
# =============================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_REALM=pwa

# =============================================================================
# Keycloak URLs
# KEYCLOAK_INTERNAL_URL — container-to-container (backend → keycloak JWKS)
# =============================================================================
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# =============================================================================
# Backend
# =============================================================================
SECRET_KEY=changeme
BACKEND_CORS_ORIGINS='["https://localhost", "https://localhost:4443"]'
LOG_LEVEL=info

# =============================================================================
# pgAdmin
# =============================================================================
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=changeme

# =============================================================================
# Traefik / TLS
# =============================================================================
TLS_MODE=local
DOMAIN=localhost
ACME_EMAIL=your@email.com
