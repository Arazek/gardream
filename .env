# =============================================================================
# App — PostgreSQL connection (backend uses these)
# POSTGRES_USER is also the postgres superuser for the infra stack
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app_db

# =============================================================================
# App — Keycloak connection (backend uses these)
# =============================================================================
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_PUBLIC_URL=https://keycloak.localhost
KEYCLOAK_REALM=gardream

# =============================================================================
# App — Backend
# =============================================================================
SECRET_KEY=changeme
BACKEND_CORS_ORIGINS='["https://localhost", "https://localhost:4443", "http://localhost:4200", "http://localhost:8000"]'
LOG_LEVEL=info

# =============================================================================
# Infra — Keycloak database (created by infra/postgres/init.sh)
# =============================================================================
KEYCLOAK_DB=keycloak_db
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=changeme

# =============================================================================
# Infra — Keycloak admin console
# =============================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_HOSTNAME=keycloak.localhost

# =============================================================================
# Infra — Traefik
# =============================================================================
TRAEFIK_DASHBOARD_HOST=traefik.localhost
# Generate new hash: docker run --rm httpd:2-alpine htpasswd -nbB admin yourpassword
# Default: admin / changeme_dashboard
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$oa5OAzEci2Tt1hrCNwn7b.c2Yyi5yPATnZeRI4V19m1PXhWpVUJI.

# =============================================================================
# Infra — pgAdmin
# =============================================================================
PGADMIN_HOSTNAME=pgadmin.localhost
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=changeme
# Must match "secret" for the pgadmin client in infra/keycloak/realm-config.json
PGADMIN_OAUTH_CLIENT_SECRET=changeme_pgadmin_secret

# =============================================================================
# Infra — Webhook (automated deployments)
# =============================================================================
WEBHOOK_HOSTNAME=webhook.localhost
WEBHOOK_SECRET=changeme

# =============================================================================
# Infra — TLS / domain (prod only)
# =============================================================================
TLS_MODE=local
DOMAIN=localhost
ACME_EMAIL=your@email.com
